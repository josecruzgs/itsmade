# =============================================================================
# Variables del VPS (solo Evolution + Postgres + Redis)
# Copia a `.env` junto al docker-compose.evolution-only.yml
# =============================================================================

# URL publica HTTPS del subdominio donde Evolution sera accesible.
# Tu reverse proxy del panel debe servir este subdominio y proxy_pass al
# contenedor itsmade-evolution-api en su red interna (puerto 8080).
EVOLUTION_PUBLIC_URL=https://evolution.itsmade.tudominio.com

# URL del webhook en Vercel donde Evolution entregara los mensajes.
# El path /api/webhook/evolution NO cambia (es el route handler de Next.js).
VERCEL_WEBHOOK_URL=https://itsmade.vercel.app/api/webhook/evolution

# Global API key. Debe coincidir con EVOLUTION_API_KEY del .env de Vercel.
# Generar con:  openssl rand -hex 32
EVOLUTION_API_KEY=

# Password de Postgres interno de Evolution (NO es Supabase).
# Generar con:  openssl rand -hex 24
# Importante: sin caracteres especiales para evitar problemas con la URI de conexion.
EVOLUTION_DB_PASSWORD=
