# =============================================================================
# itsMade — Variables de entorno
# Copia este archivo a `.env.local` para desarrollo local, o configura los
# mismos en Vercel Dashboard -> Settings -> Environment Variables para prod.
# =============================================================================

# === App ======================================================================
# URL pública de la app Next.js (con https en prod, sin slash final).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# === Supabase =================================================================
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Bucket de Storage (no se usa en este sprint pero queda preparado para reportes PDF futuros).
SUPABASE_STORAGE_BUCKET=feedback

# === Anthropic (Claude) =======================================================
ANTHROPIC_API_KEY=
# Modelo conversacional del agente de feedback. Se puede sobreescribir por agente
# en src/lib/agents/_shared/anthropic.ts si en el futuro hay agentes con modelos distintos.
ANTHROPIC_MODEL=claude-sonnet-4-6

# === Evolution API (WhatsApp) =================================================
# URL pública de Evolution. En dev local con docker-compose es http://localhost:8082;
# en prod (VPS) es el subdominio HTTPS que apunta al contenedor (ej:
# https://evolution.itsmade.tudominio.com).
EVOLUTION_API_URL=http://localhost:8082

# Global API key — debe coincidir con AUTHENTICATION_API_KEY del docker-compose.
EVOLUTION_API_KEY=

# Nombre de la instancia (debe coincidir con la que crees en Evolution Manager).
EVOLUTION_INSTANCE_NAME=itsmade

# Token por-instancia (solo Evolution v2 lo usa para firmar webhooks).
# Lo ves en Evolution Manager al crear la instancia, campo "Token". Opcional.
EVOLUTION_INSTANCE_TOKEN=

# Si quieres sobrescribir la URL del webhook que recibe Evolution (raro), descomenta:
# EVOLUTION_WEBHOOK_GLOBAL_URL=https://itsmade.vercel.app/api/webhook/evolution

# === Cron =====================================================================
# Bearer secret que Vercel Cron envía en el header Authorization.
# Si se deja vacío, los endpoints /api/cron/* aceptan llamadas sin auth (útil en dev).
CRON_SECRET=

# Horas de inactividad antes de auto-cerrar conversaciones.
CONVERSATION_AUTO_CLOSE_HOURS=72

# Horas tras el envio del opening sin respuesta para marcar feedback_request como expired.
FEEDBACK_REQUEST_EXPIRY_HOURS=48

# === Branding (opcional) ======================================================
ITSMADE_BRAND_NAME=itsMade
ITSMADE_SUPPORT_PHONE=
ITSMADE_WEBSITE=itsmade.com.mx
